---
import "@/styles/global.css";
import { ConverterApp } from "@/components/converter-app";
import { execSync } from "node:child_process";

const commitRef = getCommitRef();
const siteUrl = "https://pdf.q9m3.com/";
const ogImageUrl = `${siteUrl}og.png`;
const pageTitle = "PDF Converter | Convert PDF to JPG, PNG, WebP, or BMP";
const pageDescription =
  "Convert PDF pages to JPG, PNG, WebP, or BMP images in your browser. Free, private, batch-friendly PDF conversion with no file uploads.";
// Site verification meta tags (conditional on env vars)
const SITE_VERIFICATION_META = [
  { env: 'PUBLIC_GOOGLE_SITE_VERIFICATION' as const, name: 'google-site-verification' },
  { env: 'PUBLIC_BING_SITE_VERIFICATION' as const, name: 'msvalidate.01' },
  { env: 'PUBLIC_YANDEX_SITE_VERIFICATION' as const, name: 'yandex-verification' },
  { env: 'PUBLIC_BAIDU_SITE_VERIFICATION' as const, name: 'baidu-site-verification' },
];

const verificationMeta = SITE_VERIFICATION_META
  .filter(m => import.meta.env[m.env])
  .map(m => ({ name: m.name, content: import.meta.env[m.env] as string }));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "PDF Converter",
  url: siteUrl,
  applicationCategory: "UtilitiesApplication",
  operatingSystem: "Any",
  description: pageDescription,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD"
  },
  featureList: [
    "Convert PDF pages to JPG images",
    "Convert PDF pages to PNG images",
    "Convert PDF pages to WebP images",
    "Convert PDF pages to BMP images",
    "Batch PDF conversion",
    "Browser-based local file processing"
  ]
};

function getCommitRef() {
  const envCommit =
    import.meta.env.PUBLIC_COMMIT_SHA ||
    import.meta.env.CF_PAGES_COMMIT_SHA ||
    import.meta.env.VERCEL_GIT_COMMIT_SHA;

  if (envCommit) {
    return envCommit.slice(0, 7);
  }

  try {
    return execSync("git rev-parse --short HEAD", { encoding: "utf-8" }).trim();
  } catch {
    return "unknown";
  }
}
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content="PDF converter, PDF to JPG, PDF to PNG, PDF to WebP, PDF to BMP, convert PDF to image, browser PDF converter, private PDF conversion, batch PDF converter" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="PDF Converter" />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" type="image/png" sizes="128x128" href="/favicon-dark-128.png" />
    {verificationMeta.map(m => <meta name={m.name} content={m.content} />)}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="PDF Converter" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="PDF Converter browser-based PDF to image conversion" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="PDF Converter browser-based PDF to image conversion" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <!-- Microsoft Clarity analytics -->
    <script is:inline type="text/javascript">
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "vtzz5hczt5");
    </script>
  </head>
  <body>
    <ConverterApp commitRef={commitRef} client:load />
  </body>
</html>
