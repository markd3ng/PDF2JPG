---
import "@/styles/global.css";
import { ConverterApp } from "@/components/converter-app";
import { execSync } from "node:child_process";

const commitRef = getCommitRef();
const siteUrl = "https://pdf.q9m3.com/";
const ogImageUrl = `${siteUrl}og.png`;
const pageTitle = "PDF Converter | Convert PDF to JPG, PNG, WebP, or BMP";
const pageDescription =
  "Convert PDF pages to JPG, PNG, WebP, or BMP images in your browser. Free, private, batch-friendly PDF conversion with no file uploads.";
// Site verification meta tags (conditional on env vars)
const SITE_VERIFICATION_META = [
  { env: 'PUBLIC_GOOGLE_SITE_VERIFICATION' as const, name: 'google-site-verification' },
  { env: 'PUBLIC_BING_SITE_VERIFICATION' as const, name: 'msvalidate.01' },
  { env: 'PUBLIC_YANDEX_SITE_VERIFICATION' as const, name: 'yandex-verification' },
  { env: 'PUBLIC_BAIDU_SITE_VERIFICATION' as const, name: 'baidu-site-verification' },
];

const verificationMeta = SITE_VERIFICATION_META
  .filter(m => import.meta.env[m.env])
  .map(m => ({ name: m.name, content: import.meta.env[m.env] as string }));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  name: "PDF Converter",
  url: siteUrl,
  applicationCategory: "UtilitiesApplication",
  operatingSystem: "Any",
  description: pageDescription,
  offers: {
    "@type": "Offer",
    price: "0",
    priceCurrency: "USD"
  },
  featureList: [
    "Convert PDF pages to JPG images",
    "Convert PDF pages to PNG images",
    "Convert PDF pages to WebP images",
    "Convert PDF pages to BMP images",
    "Batch PDF conversion",
    "Browser-based local file processing"
  ]
};

function getCommitRef() {
  const envCommit =
    import.meta.env.PUBLIC_COMMIT_SHA ||
    import.meta.env.CF_PAGES_COMMIT_SHA ||
    import.meta.env.VERCEL_GIT_COMMIT_SHA;

  if (envCommit) {
    return envCommit.slice(0, 7);
  }

  try {
    return execSync("git rev-parse --short HEAD", { encoding: "utf-8" }).trim();
  } catch {
    return "unknown";
  }
}
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content="PDF converter, PDF to JPG, PDF to PNG, PDF to WebP, PDF to BMP, convert PDF to image, browser PDF converter, private PDF conversion, batch PDF converter" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="PDF Converter" />
    <link rel="canonical" href={siteUrl} />
    <link rel="icon" type="image/png" sizes="128x128" href="/favicon-dark-128.png" />
    {verificationMeta.map(m => <meta name={m.name} content={m.content} />)}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="PDF Converter" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="PDF Converter browser-based PDF to image conversion" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content="PDF Converter browser-based PDF to image conversion" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <!-- Google Analytics 4 -->
    {import.meta.env.PUBLIC_GA_ID && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA_ID}`}></script>
        <script>
          window.dataLayer = window.dataLayer || [];
          function gtag(){{dataLayer.push(arguments);}}
          gtag('js', new Date());
          gtag('config', import.meta.env.PUBLIC_GA_ID);
        </script>
      </>
    )}
    <!-- Microsoft Clarity -->
    {import.meta.env.PUBLIC_CLARITY_ID && (
      <script>
        (function(c,l,a,r,i,t,y){{
          c[a]=c[a]||function(){{(c[a].q=c[a].q||[]).push(arguments)}};
          t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
          y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
        }})(window, document, "clarity", "script", import.meta.env.PUBLIC_CLARITY_ID);
      </script>
    )}
    <!-- Plausible Analytics -->
    {import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN && (
      <script defer
        data-domain={import.meta.env.PUBLIC_PLAUSIBLE_DOMAIN}
        src={import.meta.env.PUBLIC_PLAUSIBLE_SRC || 'https://plausible.io/js/script.js'}>
      </script>
    )}
    <!-- Fathom Analytics -->
    {import.meta.env.PUBLIC_FATHOM_SITE_ID && (
      <script
        src={import.meta.env.PUBLIC_FATHOM_SRC || 'https://cdn.usefathom.com/script.js'}
        data-site={import.meta.env.PUBLIC_FATHOM_SITE_ID}
        defer>
      </script>
    )}
    <!-- Umami Analytics -->
    {import.meta.env.PUBLIC_UMAMI_WEBSITE_ID && (
      <script defer
        src={import.meta.env.PUBLIC_UMAMI_SRC || 'https://cloud.umami.is/script.js'}
        data-website-id={import.meta.env.PUBLIC_UMAMI_WEBSITE_ID}>
      </script>
    )}
    <!-- Matomo Analytics -->
    {import.meta.env.PUBLIC_MATOMO_SITE_ID && import.meta.env.PUBLIC_MATOMO_URL && (
      <script>
        var _paq = window._paq = window._paq || [];
        _paq.push(['trackPageView']);
        _paq.push(['enableLinkTracking']);
        (function() {{
          var u=import.meta.env.PUBLIC_MATOMO_URL;
          _paq.push(['setTrackerUrl', u+'matomo.php']);
          _paq.push(['setSiteId', import.meta.env.PUBLIC_MATOMO_SITE_ID]);
          var d=document, g=d.createElement('script'), s=d.getElementsByTagName('script')[0];
          g.async=true; g.src=u+'matomo.js'; s.parentNode.insertBefore(g,s);
        }})();
      </script>
    )}
    <!-- Google AdSense -->
    {import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID && (
      <script is:inline async
        src={`https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=${import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID}`}
        crossorigin="anonymous">
      </script>
    )}
  </head>
  <body>
    <ConverterApp commitRef={commitRef} adsensePublisherId={import.meta.env.PUBLIC_ADSENSE_PUBLISHER_ID} client:load />
  </body>
</html>
