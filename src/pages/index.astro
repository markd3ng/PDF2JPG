    <meta name="keywords" content="PDF转JPG, PDF2JPG, PDF转图片, 在线PDF转换, 本地PDF转换, 批量PDF转换" />
    <meta name="robots" content="index, follow" />
    <meta name="author" content="PDF2JPG Team" />
    <meta property="og:title" content="PDF2JPG · 浏览器本地转换" />
    <meta property="og:description" content="PDF2JPG 支持将 PDF 文件批量转换为 JPG 图片，文件仅在浏览器本地处理，不由本工具上传；页面会加载 Microsoft Clarity 用于匿名使用统计。" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://pdf2jpg.example.com" />
    <!-- Microsoft Clarity 统计代码 -->
    <script is:inline type="text/javascript">
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "vtzz5hczt5");
