# Site Verification Codes
# Set these in your deployment environment (Cloudflare Pages, Vercel, Netlify)
# to enable search engine site ownership verification.

# Google Search Console
# PUBLIC_GOOGLE_SITE_VERIFICATION=

# Bing Webmaster Tools
# PUBLIC_BING_SITE_VERIFICATION=

# Yandex Webmaster
# PUBLIC_YANDEX_SITE_VERIFICATION=

# Baidu Zhanzhang
# PUBLIC_BAIDU_SITE_VERIFICATION=
